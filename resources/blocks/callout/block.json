{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "sobe/callout",
  "version": "0.1.0",
  "title": "Callout",
  "category": "sobe-blocks",
  "description": "A highlighted content section with optional CTA.",
  "textdomain": "sage",
  "supports": {
    "html": false,
    "anchor": true,
    "className": true,
    "layout": true,
    "color": {
      "background": true,
      "text": true
    },
    "spacing": {
      "padding": true,
      "margin": true
    },
    "align": ["wide", "full"]
  },
  "attributes": {
    "align": {
      "type": "string",
      "default": "wide"
    },
    "heading": {
      "type": "string",
      "default": ""
    },
    "showCta": {
      "type": "boolean",
      "default": false
    },
    "ctaText": {
      "type": "string",
      "default": ""
    },
    "ctaUrl": {
      "type": "string",
      "default": ""
    },
    "layout": {
      "type": "string",
      "enum": ["standard", "wide"],
      "default": "standard"
    }
  }
}
