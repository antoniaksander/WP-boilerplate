{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "sobe/hero",
  "version": "0.1.0",
  "title": "Hero",
  "icon": "cover-image",
  "category": "sobe-general",
  "description": "Full-bleed hero section with background image, heading, text, and optional CTA.",
  "example": {
    "attributes": {
      "heading": "Make Something Great",
      "paragraph": "A bold statement that captures attention and drives action.",
      "ctaText": "Get Started",
      "ctaUrl": "#",
      "alignment": "left",
      "height": "80vh",
      "align": "full"
    }
  },
  "supports": {
    "html": false,
    "anchor": true,
    "className": true,
    "align": ["wide", "full"],
    "layout": false
  },
  "textdomain": "sobe",
  "attributes": {
    "align": {
      "type": "string",
      "default": "wide"
    },
    "heading": {
      "type": "string",
      "default": ""
    },
    "paragraph": {
      "type": "string",
      "default": ""
    },
    "ctaText": {
      "type": "string",
      "default": ""
    },
    "ctaUrl": {
      "type": "string",
      "default": ""
    },
    "ctaType": {
      "type": "string",
      "enum": ["btn-dark", "btn-light", "btn-outline-dark", "btn-outline-light", "link-dark", "link-light"],
      "default": "btn-dark"
    },
    "alignment": {
      "type": "string",
      "enum": ["left", "center", "split-screen", "editorial"],
      "default": "left"
    },
    "height": {
      "type": "string",
      "enum": ["70vh", "80vh", "90vh", "100vh"],
      "default": "80vh"
    },
    "backgroundImageId": {
      "type": "number",
      "default": 0
    },
    "backgroundImageUrl": {
      "type": "string",
      "default": ""
    },
    "darkOverlay": {
      "type": "boolean",
      "default": true
    }
  }
}
